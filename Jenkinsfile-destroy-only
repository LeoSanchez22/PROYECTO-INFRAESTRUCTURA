pipeline {
    agent any
    
    environment {
        TF_IN_AUTOMATION = 'true'
        TF_INPUT = 'false'
        AWS_DEFAULT_REGION = 'us-east-1'
        PROJECT_PATH = '/home/leonardo-sanchez/PROYECTO-INFRAESTRUCTURA'
    }
    
    parameters {
        choice(
            name: 'WORKSPACE',
            choices: ['dev', 'staging', 'default', 'prod'],
            description: '🏢 Workspace de Terraform a DESTRUIR'
        )
        booleanParam(
            name: 'AUTO_APPROVE',
            defaultValue: false,
            description: '⚠️ DESTRUIR sin confirmación (PELIGROSO)'
        )
        string(
            name: 'TARGET_RESOURCE',
            defaultValue: '',
            description: '🎯 Recurso específico a destruir'
        )
        string(
            name: 'CONFIRMATION_TEXT',
            defaultValue: '',
            description: '⚠️ Escribe "DESTROY" para confirmar'
        )
    }
    
    stages {
        stage('🛡️ Validaciones de Seguridad') {
            steps {
                script {
                    echo "🛡️ VERIFICANDO SEGURIDAD PARA DESTROY"
                    
                    // No permitir auto-approve en prod
                    if (params.WORKSPACE == 'prod' && params.AUTO_APPROVE) {
                        error("🚨 ERROR: AUTO_APPROVE no permitido en producción")
                    }
                    
                    // Verificar texto de confirmación si auto-approve
                    if (params.AUTO_APPROVE && params.CONFIRMATION_TEXT != 'DESTROY') {
                        error("🚨 ERROR: Debes escribir 'DESTROY' en CONFIRMATION_TEXT")
                    }
                    
                    echo "✅ Validaciones pasadas"
                    echo "⚠️ WORKSPACE A DESTRUIR: ${params.WORKSPACE}"
                }
            }
        }
        
        stage('🔧 Verificación') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "🗑️ TERRAFORM DESTROY PIPELINE"
                    echo "📁 Directorio: $(pwd)"
                    echo "🏢 Workspace: ${WORKSPACE}"
                    echo "⚠️ OPERACIÓN DESTRUCTIVA"
                    
                    # Verificar herramientas
                    terraform version
                    aws --version
                    aws sts get-caller-identity
                    
                    # Verificar archivos
                    ls -la *.tf
                '''
            }
        }
        
        stage('🏢 Setup Workspace') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    terraform init -upgrade
                    
                    CURRENT_WS=$(terraform workspace show)
                    if [ "$CURRENT_WS" != "${WORKSPACE}" ]; then
                        if terraform workspace select "${WORKSPACE}" 2>/dev/null; then
                            echo "✅ Workspace seleccionado: ${WORKSPACE}"
                        else
                            echo "❌ Workspace ${WORKSPACE} no existe"
                            terraform workspace list
                            exit 1
                        fi
                    fi
                    
                    echo "✅ Workspace activo: $(terraform workspace show)"
                '''
            }
        }
        
        stage('📋 Inventario Pre-Destroy') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "📋 RECURSOS A DESTRUIR:"
                    
                    RESOURCE_COUNT=$(terraform state list 2>/dev/null | wc -l || echo "0")
                    echo "📈 Total de recursos: $RESOURCE_COUNT"
                    
                    if [ "$RESOURCE_COUNT" -gt 0 ]; then
                        terraform state list
                        
                        echo ""
                        echo "📤 Outputs que se perderán:"
                        terraform output 2>/dev/null || echo "No hay outputs"
                    else
                        echo "ℹ️ No hay recursos para destruir"
                    fi
                '''
            }
        }
        
        stage('🗑️ Plan Destroy') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "🗑️ Generando plan de destrucción..."
                    
                    PLAN_CMD="terraform plan -destroy -input=false -out=destroy.tfplan"
                    if [ -n "${TARGET_RESOURCE}" ]; then
                        echo "🎯 Destrucción específica: ${TARGET_RESOURCE}"
                        PLAN_CMD="$PLAN_CMD -target=${TARGET_RESOURCE}"
                    else
                        echo "⚠️ DESTRUCCIÓN COMPLETA"
                    fi
                    
                    $PLAN_CMD
                    terraform show -no-color destroy.tfplan | head -30
                '''
            }
        }
        
        stage('⚠️ Confirmación DESTROY') {
            when {
                expression { !params.AUTO_APPROVE }
            }
            steps {
                script {
                    echo "🚨 CONFIRMACIÓN REQUERIDA PARA DESTRUIR"
                    echo "════════════════════════════════════════════════════════════════════════"
                    echo "⚠️ OPERACIÓN DESTRUCTIVA - NO REVERSIBLE"
                    echo "🏢 Workspace: ${params.WORKSPACE}"
                    if (params.TARGET_RESOURCE) {
                        echo "🎯 Recurso: ${params.TARGET_RESOURCE}"
                    } else {
                        echo "🎯 TODA LA INFRAESTRUCTURA"
                    }
                    echo "════════════════════════════════════════════════════════════════════════"
                    
                    timeout(time: 15, unit: 'MINUTES') {
                        input message: '🚨 ¿CONFIRMAS DESTRUIR estos recursos?\\n\\n⚠️ NO ES REVERSIBLE ⚠️', 
                              ok: '🗑️ SÍ, DESTRUIR',
                              submitterParameter: 'DESTROYER'
                    }
                    echo "⚠️ Destrucción autorizada por: ${env.DESTROYER}"
                }
            }
        }
        
        stage('🗑️ Destroy') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "🗑️ DESTRUYENDO INFRAESTRUCTURA..."
                    echo "⚠️ OPERACIÓN IRREVERSIBLE EN PROGRESO"
                    
                    terraform apply -input=false destroy.tfplan
                    
                    echo ""
                    echo "✅ Destroy completado"
                    
                    # Verificar recursos restantes
                    REMAINING=$(terraform state list 2>/dev/null | wc -l || echo "0")
                    if [ "$REMAINING" -eq 0 ]; then
                        echo "✅ No quedan recursos"
                    else
                        echo "⚠️ Quedan $REMAINING recursos:"
                        terraform state list
                    fi
                '''
            }
        }
        
        stage('🔍 Verificación Post-Destroy') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "🔍 Verificación final:"
                    
                    REMAINING=$(terraform state list 2>/dev/null | wc -l || echo "0")
                    echo "📈 Recursos restantes: $REMAINING"
                    
                    if [ "$REMAINING" -eq 0 ]; then
                        echo "✅ Estado limpio - destrucción completa"
                    else
                        echo "⚠️ Recursos que no se pudieron destruir:"
                        terraform state list
                    fi
                    
                    echo ""
                    echo "🔍 Verificación AWS:"
                    echo "👤 Usuario: $(aws sts get-caller-identity --query 'Arn' --output text)"
                '''
            }
        }
    }
    
    post {
        always {
            sh '''
                cd "${PROJECT_PATH}"
                rm -f destroy.tfplan
                echo ""
                echo "📋 RESUMEN DESTROY:"
                echo "════════════════════════════════════════════════════════════════════════"
                echo "🗑️ Operación: DESTROY"
                echo "🏢 Workspace: ${WORKSPACE}"
                echo "📁 Directorio: ${PROJECT_PATH}"
                echo "⏰ Completado: $(date)"
                echo "════════════════════════════════════════════════════════════════════════"
            '''
        }
        success {
            echo "🎉 ¡DESTRUCCIÓN COMPLETADA EXITOSAMENTE!"
            echo "✅ Infraestructura eliminada"
            echo "🔍 Verifica que no hay recursos huérfanos en AWS"
        }
        failure {
            echo "❌ ERROR EN TERRAFORM DESTROY"
            echo "⚠️ Algunos recursos pueden estar en estado intermedio"
            echo "🔍 Revisa el estado: terraform state list"
            echo "💡 Considera destrucción manual de recursos problemáticos"
        }
        aborted {
            echo "⏹️ DESTROY CANCELADO"
            echo "💾 Estado en punto intermedio"
            echo "🔍 Revisa: terraform state list"
        }
    }
}
