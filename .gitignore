# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local development
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# AWS CLI installation files
awscliv2.zip

# Lambda deployment packages

# Local environment files
.env
.env.*

# Log files
*.log

# IDE and editor directories
.idea/
.vscode/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

monitoring/monitoring/.env

# Node.js dependencies
node_modules/
*/node_modules/
**/node_modules/

# npm/yarn files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
