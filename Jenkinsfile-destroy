#!/usr/bin/env groovy

pipeline {
    agent any
    
    parameters {
        booleanParam(
            name: 'AUTO_APPROVE',
            defaultValue: false,
            description: 'Automatically approve and destroy Terraform infrastructure'
        )
        choice(
            name: 'TERRAFORM_ACTION',
            choices: ['plan', 'destroy'],
            description: 'Select Terraform action to perform'
        )
    }
    
    environment {
        TERRAFORM_DIR = '/home/leonardo-sanchez/PROYECTO-INFRAESTRUCTURA'
        AWS_DEFAULT_REGION = 'us-east-1'
        TF_IN_AUTOMATION = 'true'
        TF_INPUT = '0'
    }
    
    stages {
        stage('Checkout') {
            steps {
                script {
                    echo "Working directly in: ${env.TERRAFORM_DIR}"
                }
            }
        }
        
        stage('Terraform Init') {
            steps {
                dir("${env.TERRAFORM_DIR}") {
                    script {
                        echo "Initializing Terraform in ${env.TERRAFORM_DIR}"
                        sh '''
                            #!/bin/bash
                            set -e
                            terraform --version
                            terraform init -input=false
                        '''
                    }
                }
            }
        }
        
        stage('Terraform Plan Destroy') {
            steps {
                dir("${env.TERRAFORM_DIR}") {
                    script {
                        echo "Creating Terraform execution plan for destroy"
                        sh '''
                            #!/bin/bash
                            set -e
                            terraform plan -destroy -input=false -out=tfdestroyplan
                            echo "Destroy plan created successfully"
                        '''
                    }
                }
            }
        }
        
        stage('Terraform Destroy') {
            when {
                anyOf {
                    allOf {
                        params.TERRAFORM_ACTION == 'destroy'
                        params.AUTO_APPROVE == true
                    }
                    allOf {
                        params.TERRAFORM_ACTION == 'destroy'
                        params.AUTO_APPROVE == false
                    }
                }
            }
            steps {
                dir("${env.TERRAFORM_DIR}") {
                    script {
                        if (params.AUTO_APPROVE) {
                            echo "Auto-destroying Terraform infrastructure"
                            sh '''
                                #!/bin/bash
                                set -e
                                terraform destroy -input=false -auto-approve
                                echo "Terraform destroy completed successfully"
                            '''
                        } else {
                            echo "Manual approval required for Terraform destroy"
                            input message: 'Do you want to destroy the Terraform infrastructure?', ok: 'Destroy',
                                  submitterParameter: 'APPROVER'
                            echo "Approved by: ${env.APPROVER}"
                            sh '''
                                #!/bin/bash
                                set -e
                                terraform destroy -input=false -auto-approve
                                echo "Terraform destroy completed successfully"
                            '''
                        }
                    }
                }
            }
        }
    }
    
    post {
        always {
            dir("${env.TERRAFORM_DIR}") {
                script {
                    // Clean up plan file
                    sh '''
                        #!/bin/bash
                        if [ -f tfdestroyplan ]; then
                            rm -f tfdestroyplan
                            echo "Cleaned up terraform destroy plan file"
                        fi
                    '''
                }
            }
        }
        success {
            echo "Terraform destroy pipeline completed successfully!"
        }
        failure {
            echo "Terraform destroy pipeline failed. Check the logs for details."
        }
    }
}
