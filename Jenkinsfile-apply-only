pipeline {
    agent any
    
    environment {
        TF_IN_AUTOMATION = 'true'
        TF_INPUT = 'false'
        AWS_DEFAULT_REGION = 'us-east-1'
        PROJECT_PATH = '/home/leonardo-sanchez/PROYECTO-INFRAESTRUCTURA'
    }
    
    parameters {
        choice(
            name: 'WORKSPACE',
            choices: ['default', 'dev', 'staging', 'prod'],
            description: '🏢 Workspace de Terraform'
        )
        booleanParam(
            name: 'AUTO_APPROVE',
            defaultValue: false,
            description: '⚡ Aplicar sin confirmación manual'
        )
        string(
            name: 'TARGET_RESOURCE',
            defaultValue: '',
            description: '🎯 Recurso específico (opcional)'
        )
    }
    
    stages {
        stage('🔧 Verificación') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "🚀 TERRAFORM APPLY PIPELINE"
                    echo "📁 Directorio: $(pwd)"
                    echo "🏢 Workspace: ${WORKSPACE}"
                    
                    # Verificar herramientas
                    terraform version
                    aws --version
                    aws sts get-caller-identity
                    
                    # Verificar archivos
                    ls -la *.tf
                '''
            }
        }
        
        stage('🏢 Setup Workspace') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    terraform init -upgrade
                    
                    CURRENT_WS=$(terraform workspace show)
                    if [ "$CURRENT_WS" != "${WORKSPACE}" ]; then
                        terraform workspace select "${WORKSPACE}" || terraform workspace new "${WORKSPACE}"
                    fi
                    
                    echo "✅ Workspace activo: $(terraform workspace show)"
                '''
            }
        }
        
        stage('📋 Plan') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "📋 Generando plan de Terraform..."
                    
                    PLAN_CMD="terraform plan -input=false -out=tfplan"
                    if [ -n "${TARGET_RESOURCE}" ]; then
                        PLAN_CMD="$PLAN_CMD -target=${TARGET_RESOURCE}"
                    fi
                    
                    $PLAN_CMD
                    terraform show -no-color tfplan | head -30
                '''
            }
        }
        
        stage('✋ Confirmación') {
            when {
                expression { !params.AUTO_APPROVE }
            }
            steps {
                script {
                    timeout(time: 10, unit: 'MINUTES') {
                        input message: '¿Aplicar estos cambios de Terraform?', 
                              ok: '✅ Sí, aplicar',
                              submitterParameter: 'APPROVER'
                    }
                    echo "✅ Aprobado por: ${env.APPROVER}"
                }
            }
        }
        
        stage('🚀 Apply') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "🚀 Aplicando infraestructura..."
                    
                    terraform apply -input=false tfplan
                    
                    echo "✅ Apply completado"
                    echo "📤 Outputs:"
                    terraform output || echo "No hay outputs"
                '''
            }
        }
        
        stage('🔍 Verificación') {
            steps {
                sh '''
                    cd "${PROJECT_PATH}"
                    echo "🔍 Estado final:"
                    echo "📈 Recursos: $(terraform state list | wc -l)"
                    terraform state list | head -10
                    terraform output
                '''
            }
        }
    }
    
    post {
        always {
            sh '''
                cd "${PROJECT_PATH}"
                rm -f tfplan
                echo "🎉 TERRAFORM APPLY COMPLETADO"
                echo "📁 Directorio: ${PROJECT_PATH}"
                echo "🏢 Workspace: ${WORKSPACE}"
            '''
        }
        success {
            echo "✅ ¡INFRAESTRUCTURA APLICADA EXITOSAMENTE!"
        }
        failure {
            echo "❌ ERROR EN TERRAFORM APPLY"
            echo "🔍 Revisa los logs y el estado actual"
        }
    }
}
